{
    "title": "Job Processing",
    "uid": "transcribo-job-processing",
    "panels": [
      {
        "title": "Queue Size",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "transcribo_job_queue_size{status=\"pending\"}"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "title": "Jobs by Status",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "sum(transcribo_job_queue_size) by (status)",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "title": "Job Processing Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate(transcribo_job_processing_duration_seconds_sum[5m]) / rate(transcribo_job_processing_duration_seconds_count[5m])",
            "legendFormat": "Average Processing Time"
          }
        ]
      },
      {
        "title": "Job Success Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "sum(rate(transcribo_jobs_total{status=\"completed\"}[5m])) / sum(rate(transcribo_jobs_total{status=~\"completed|failed\"}[5m])) * 100"
          }
        ],
        "options": {
          "maxValue": 100,
          "minValue": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      {
        "title": "Jobs Completed vs Failed",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(transcribo_jobs_total{status=\"completed\"}[5m])",
            "legendFormat": "Completed"
          },
          {
            "expr": "rate(transcribo_jobs_total{status=\"failed\"}[5m])",
            "legendFormat": "Failed"
          }
        ]
      }
    ],
    "refresh": "10s",
    "time": {
      "from": "now-6h",
      "to": "now"
    }
  }