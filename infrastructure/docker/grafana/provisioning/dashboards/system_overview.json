{
    "title": "Transcribo System Overview",
    "uid": "transcribo-system-overview",
    "panels": [
      {
        "title": "CPU Usage by Container",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])",
            "legendFormat": "{{container}}"
          }
        ]
      },
      {
        "title": "Memory Usage by Container",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "container_memory_usage_bytes{container!=\"\"}",
            "legendFormat": "{{container}}"
          }
        ]
      },
      {
        "title": "Network Traffic",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(container_network_transmit_bytes_total[5m])",
            "legendFormat": "TX {{container}}"
          },
          {
            "expr": "rate(container_network_receive_bytes_total[5m])",
            "legendFormat": "RX {{container}}"
          }
        ]
      },
      {
        "title": "Disk Usage",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} * 100) / node_filesystem_size_bytes{mountpoint=\"/\"})"
          }
        ],
        "options": {
          "maxValue": 100,
          "minValue": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    ],
    "refresh": "10s",
    "schemaVersion": 38,
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {}
  }