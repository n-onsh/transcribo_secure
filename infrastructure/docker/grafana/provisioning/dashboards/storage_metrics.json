{
    "title": "Storage Metrics",
    "uid": "transcribo-storage-metrics",
    "panels": [
      {
        "title": "Storage Usage by Type",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "transcribo_storage_bytes",
            "legendFormat": "{{type}}"
          }
        ]
      },
      {
        "title": "Storage Operations Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate(transcribo_storage_operations_total[5m])",
            "legendFormat": "{{operation}}"
          }
        ]
      },
      {
        "title": "File Upload Size Distribution",
        "type": "histogram",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(transcribo_file_upload_bytes_bucket[5m])",
            "format": "heatmap",
            "legendFormat": "{{le}}"
          }
        ]
      },
      {
        "title": "Encryption Operation Duration",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(transcribo_encryption_duration_seconds_sum[5m]) / rate(transcribo_encryption_duration_seconds_count[5m])",
            "legendFormat": "Average Duration"
          }
        ]
      },
      {
        "title": "Storage Operation Success Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "sum(rate(transcribo_storage_operations_total{status=\"success\"}[5m])) / sum(rate(transcribo_storage_operations_total[5m])) * 100"
          }
        ],
        "options": {
          "maxValue": 100,
          "minValue": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    ],
    "refresh": "10s",
    "time": {
      "from": "now-6h",
      "to": "now"
    }
  }