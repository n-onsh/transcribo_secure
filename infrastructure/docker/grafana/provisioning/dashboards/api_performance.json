{
    "title": "API Performance",
    "uid": "transcribo-api-performance",
    "panels": [
      {
        "title": "Request Rate by Endpoint",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(transcribo_http_requests_total{endpoint!=\"/metrics\"}[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ]
      },
      {
        "title": "Response Time Distribution",
        "type": "histogram",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate(transcribo_http_request_duration_seconds_bucket[5m])",
            "format": "heatmap",
            "legendFormat": "{{le}}"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(transcribo_http_requests_total{status=~\"5.*\"}[5m])) / sum(rate(transcribo_http_requests_total[5m])) * 100",
            "legendFormat": "Error Rate %"
          }
        ],
        "options": {
          "alertThreshold": true
        },
        "thresholds": [
          {
            "colorMode": "critical",
            "fill": true,
            "line": true,
            "op": "gt",
            "value": 5,
            "visible": true
          }
        ]
      },
      {
        "title": "Database Operations",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(transcribo_db_operations_total[5m])",
            "legendFormat": "{{operation}}"
          }
        ]
      }
    ],
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }